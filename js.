import express from 'express';
import cors from 'cors';
import dotenv from 'dotenv';
import OpenAI from 'openai';

dotenv.config();
const app = express();
const client = new OpenAI({ apiKey: process.env.OPENAI_API_KEY });

app.use(cors());
app.use(express.json({ limit: '1mb' }));
app.use(express.static('public'));

function extractSources(resp) {
  const out = [];
  const items = resp.output || [];
  for (const item of items) {
    const content = item.content || [];
    for (const c of content) {
      const ann = c.annotations || [];
      for (const a of ann) {
        if (a.url) out.push({ title: a.title || a.url, url: a.url });
      }
    }
  }
  return [...new Map(out.map(x => [x.url, x])).values()].slice(0, 8);
}

function moodInstructions(mode) {
  const base = `
You are a chatbot with emotional intelligence and factual discipline.

Rules:
- If the user asks a direct factual question, be concise, accurate, and precise.
- If the user seems sad, respond gently, warmly, and supportive.
- If the user is joking or playful, use light humor or a short joke when appropriate.
- If the user asks for a story or creative content, be vivid, engaging, and imaginative.
- Never become fake or overly theatrical.
- Never sacrifice correctness for personality.
- If you use web information, keep it sourced and accurate.
`;

  const modeRules = {
    precise: `
Style mode: precise.
- Answer in short, direct sentences.
- Avoid extra fluff.
- Provide the core answer first.
`,
    empathetic: `
Style mode: empathetic.
- Be warm, caring, and calm.
- Acknowledge feelings before giving advice.
- Avoid being robotic.
`,
    playful: `
Style mode: playful.
- Use gentle humor.
- If appropriate, add one short joke or witty line.
- Do not derail the answer.
`,
    creative: `
Style mode: creative.
- Be expressive and vivid.
- Build atmosphere and narrative.
- Make the response enjoyable to read.
`
  };

  return base + (modeRules[mode] || modeRules.precise);
}

async function classifyMode(message) {
  const text = String(message || '').toLowerCase();

  const quickHints = [
    ['sad', 'empathetic'],
    ['depressed', 'empathetic'],
    ['upset', 'empathetic'],
    ['cry', 'empathetic'],
    ['joke', 'playful'],
    ['funny', 'playful'],
    ['laugh', 'playful'],
    ['story', 'creative'],
    ['write me a story', 'creative'],
    ['tell me a story', 'creative']
  ];

  for (const [needle, mode] of quickHints) {
    if (text.includes(needle)) return mode;
  }

  const classification = await client.responses.create({
    model: 'gpt-4.1',
    input: [
      {
        role: 'system',
        content:
          'Classify the user message into exactly one label: precise, empathetic, playful, creative.'
      },
      {
        role: 'user',
        content: `User message: ${message}\n\nReturn only one label.`
      }
    ]
  });

  const label = (classification.output_text || '').trim().toLowerCase();
  if (['precise', 'empathetic', 'playful', 'creative'].includes(label)) return label;
  return 'precise';
}

app.post('/api/chat', async (req, res) => {
  try {
    const messages = req.body.messages || [];
    const lastUserMessage = [...messages].reverse().find(m => m.role === 'user')?.content || '';
    const mode = await classifyMode(lastUserMessage);

    const input = messages.map(m => ({ role: m.role, content: m.content }));

    const response = await client.responses.create({
      model: 'gpt-4.1',
      instructions: moodInstructions(mode),
      input,
      tools: [{ type: 'web_search' }],
      tool_choice: 'auto'
    });

    const answer = response.output_text || 'No answer returned.';
    const sources = extractSources(response);

    res.json({ answer, sources, mode });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

app.get('/health', (_, res) => res.json({ ok: true }));

const port = process.env.PORT || 3000;
app.listen(port, () => console.log(`Server running on ${port}`));
